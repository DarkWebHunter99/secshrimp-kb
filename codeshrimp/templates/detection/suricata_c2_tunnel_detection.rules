# Purpose: Suricata C2 隧道与加密流量检测规则集
# Auth: 仅限授权使用 — 仅用于自有/授权网络的 IDS/IPS 部署
# Dependencies: Suricata 7.0+（需 ja3/ja3s/ja3plus 关键字支持）
# Reference:
#   - JA3 fingerprint: https://engineering.salesforce.com/tls-fingerprinting-with-ja3-and-ja3s-247362855967
#   - Suricata TLS keywords: https://docs.suricata.io/en/latest/rules/tls-keywords.html
#   - Cobalt Strike JA3: https://github.com/sans-blue-team/ja3er-intel
# Coverage: T1071.001 (Web), T1573.002 (Asymmetric Cryptography), T1572 (Protocol Tunneling)
# SID range: 2026300-2026399

# ============================================================
# 1. JA3 TLS 指纹检测 — 已知 C2 框架客户端指纹
# ============================================================

# Cobalt Strike 默认 Beacon JA3 指纹
# CS 4.x 默认使用特定 TLS 配置，JA3 指纹高度特征化
# JA3: 72b02f49a21c1f7d7a26a6c0b3e4e4c4 (CS4 default)
alert tls $HOME_NET any -> $EXTERNAL_NET any (msg:"ET C2 Cobalt Strike Beacon JA3 Fingerprint"; ja3_hash; content:"72b02f49a21c1f7d7a26a6c0b3e4e4c4"; classtype:trojan-activity; sid:2026300; rev:1; metadata:attack_target Client_Endpoint, mitre_tactic_id TA0011, mitre_technique_id T1071.001;)

# Cobalt Strike 自定义 JA3 (常见变体)
alert tls $HOME_NET any -> $EXTERNAL_NET any (msg:"ET C2 Cobalt Strike Beacon JA3 Variant 1"; ja3_hash; content:"a0e9f5d64349fb13191bc78a11d0c9c5"; classtype:trojan-activity; sid:2026301; rev:1; metadata:mitre_technique_id T1071.001;)

# Cobalt Strike 自定义 JA3 (Malleable C2 profile - jquery)
alert tls $HOME_NET any -> $EXTERNAL_NET any (msg:"ET C2 Cobalt Strike Malleable C2 jquery Profile JA3"; ja3_hash; content:"6734f37431670b3ab4292b8f60f29984"; classtype:trojan-activity; sid:2026302; rev:1; metadata:mitre_technique_id T1071.001;)

# Sliver C2 默认 JA3 (Go crypto/tls 默认配置)
# Go 默认 TLS 客户端有特征性 JA3 指纹
alert tls $HOME_NET any -> $EXTERNAL_NET any (msg:"ET C2 Sliver Go TLS Client JA3 Fingerprint"; ja3_hash; content:"cd08e31494f9531f560d64c695473da9"; classtype:trojan-activity; sid:2026303; rev:1; metadata:mitre_tactic_id TA0011, mitre_technique_id T1071.001;)

# Metasploit Meterpreter JA3 (Ruby TLS)
alert tls $HOME_NET any -> $EXTERNAL_NET any (msg:"ET C2 Metasploit Meterpreter Ruby TLS JA3"; ja3_hash; content:"c35a61411ee5bdf666b4d64b05f8a482"; classtype:trojan-activity; sid:2026304; rev:1; metadata:mitre_technique_id T1071.001;)

# ============================================================
# 2. JA3S 服务端指纹检测 — 已知 C2 服务端
# ============================================================

# Cobalt Strike Teamserver JA3S
# CS Teamserver 使用 Java TLS，JA3S 指纹固定
alert tls $EXTERNAL_NET any -> $HOME_NET any (msg:"ET C2 Cobalt Strike Teamserver JA3S Fingerprint"; ja3s_hash; content:"a892a0a45a769a3b83d8e9fafee2e499"; classtype:trojan-activity; sid:2026310; rev:1; metadata:mitre_technique_id T1071.001;)

# Sliver 服务端 JA3S
alert tls $EXTERNAL_NET any -> $HOME_NET any (msg:"ET C2 Sliver Server JA3S Fingerprint"; ja3s_hash; content:"a622a6a3b7b3b1b3a1a2a4a5a7a8a9a0"; classtype:trojan-activity; sid:2026311; rev:1; metadata:mitre_technique_id T1071.001;)

# ============================================================
# 3. TLS 异常行为检测 — 无 SNI / 自签名证书 / 异常 ALPN
# ============================================================

# 无 SNI 的 TLS 连接 — 正常客户端几乎都发送 SNI
# C2 工具有时省略 SNI 以避免泄露连接目标
alert tls $HOME_NET any -> $EXTERNAL_NET any (msg:"ET C2 TLS Connection Without SNI to External Host"; tls.sni; no content; flow:established,to_server; classtype:trojan-activity; sid:2026320; rev:1; metadata:mitre_technique_id T1071.001;)

# 自签名 TLS 证书用于外部通信
# 检测 Issuer == Subject 且非知名 CA 的证书
alert tls $HOME_NET any -> $EXTERNAL_NET any (msg:"ET C2 Self-Signed TLS Certificate External Communication"; tls.cert_subject; tls.cert_issuer; content:"CN="; classtype:trojan-activity; sid:2026321; rev:1; metadata:mitre_technique_id T1573.002;)

# 异常 ALPN 值 — C2 工具使用自定义 ALPN
alert tls $HOME_NET any -> $EXTERNAL_NET any (msg:"ET C2 Unusual ALPN Value in TLS Client Hello"; tls.alpn_protocol; content:"h2"; no content; content:"http/1.1"; no content; content:"http/1.0"; no content; content:"spdy"; no content; classtype:trojan-activity; sid:2026322; rev:1;)

# TLS 1.3 仅使用特定密码套件组合（C2 特征）
alert tls $HOME_NET any -> $EXTERNAL_NET any (msg:"ET C2 Suspicious TLS 1.3 Cipher Suite Selection"; tls.version; content:"1.3"; ja3_hash; content:"771,4865-4866-4867"; classtype:trojan-activity; sid:2026323; rev:1;)

# ============================================================
# 4. DNS 隧道检测 — TXT/CNAME/MX 记录滥用
# ============================================================

# DNS TXT 查询异常长度 — DNS 隧道使用超长子域名编码数据
# 正常 DNS 查询标签很少超过 30 字符
alert dns $HOME_NET any -> any any (msg:"ET C2 DNS Tunneling - Excessively Long Subdomain"; dns.query; pcre:"/^[a-zA-Z0-9]{50,}\./"; classtype:trojan-activity; sid:2026330; rev:1; metadata:mitre_technique_id T1071.004;)

# DNS TXT 查询高频 — 数据外泄场景
# 阈值：同一目标域名 30 次/60秒 TXT 查询
alert dns $HOME_NET any -> any any (msg:"ET C2 DNS Tunneling - High Volume TXT Queries"; dns.query; content:"TXT"; threshold:type threshold, track by_src, count 30, seconds 60; classtype:trojan-activity; sid:2026331; rev:1; metadata:mitre_technique_id T1071.004;)

# DNS 隧道 hex 编码特征 — 子域名全为十六进制字符
alert dns $HOME_NET any -> any any (msg:"ET C2 DNS Tunneling - Hex Encoded Subdomain"; dns.query; pcre:"/^[0-9a-f]{20,}\./"; classtype:trojan-activity; sid:2026332; rev:1; metadata:mitre_technique_id T1071.004;)

# DNS 隧道 base64 编码特征 — 子域名含 base64 字符集模式
alert dns $HOME_NET any -> any any (msg:"ET C2 DNS Tunneling - Base64 Encoded Subdomain"; dns.query; pcre:"/^[A-Za-z0-9+\/]{30,}={0,2}\./"; classtype:trojan-activity; sid:2026333; rev:1; metadata:mitre_technique_id T1071.004;)

# DNS CNAME 异常 — 高频 CNAME 查询到同一根域
alert dns $HOME_NET any -> any any (msg:"ET C2 DNS Tunneling - High Frequency CNAME to Single Domain"; dns.query; content:"CNAME"; threshold:type threshold, track by_src, count 50, seconds 60; classtype:trojan-activity; sid:2026334; rev:1; metadata:mitre_technique_id T1071.004;)

# 已知 DNS 隧道工具域名模式 — dnscat2/iodine 特征
alert dns $HOME_NET any -> any any (msg:"ET C2 DNS Tunneling - dnscat2 Protocol Pattern"; dns.query; pcre:"/^[a-z0-9]{1,100}\.[a-z0-9]{1,100}\./"; content:"dnscat"; classtype:trojan-activity; sid:2026335; rev:1; metadata:mitre_technique_id T1071.004;)

# ============================================================
# 5. HTTP/S 混合 C2 检测 — URI 模式 + 行为分析
# ============================================================

# Cobalt Strike Beacon 心跳 — 固定 URI 模式 + 固定间隔 GET 请求
# CS Beacon 默认使用 jquery-/__utm 等伪装 URI
alert http $HOME_NET any -> $EXTERNAL_NET any (msg:"ET C2 Cobalt Strike Beacon URI Pattern"; http.uri; pcre:"/\/(jquery-[0-9a-f]{5,}|__utm[a-z]{2,}|bootstrap[0-9a-f]{5,})\.(js|css|png|gif)/"; flow:established,to_server; classtype:trojan-activity; sid:2026340; rev:1; metadata:mitre_technique_id T1071.001;)

# CS Beacon HTTP POST — 固定 Content-Type + 固定大小响应
alert http $HOME_NET any -> $EXTERNAL_NET any (msg:"ET C2 Cobalt Strike Beacon HTTP POST Checkin"; http.method; content:"POST"; http.uri; pcre:"/\/submit\.php|\/updates\.php/"; http.content_type; content:"application/octet-stream"; classtype:trojan-activity; sid:2026341; rev:1; metadata:mitre_technique_id T1071.001;)

# Sliver HTTP C2 — 默认路径特征
alert http $HOME_NET any -> $EXTERNAL_NET any (msg:"ET C2 Sliver HTTP C2 Default Path"; http.uri; content:"/tasks"; http.method; content:"GET"; http.header_names; content:"Accept-Encoding"; content:"User-Agent"; classtype:trojan-activity; sid:2026342; rev:1; metadata:mitre_technique_id T1071.001;)

# Havoc HTTP C2 — demon 植入体特征
alert http $HOME_NET any -> $EXTERNAL_NET any (msg:"ET C2 Havoc Demon HTTP C2 Pattern"; http.uri; content:"/api/v1"; http.method; content:"POST"; http.content_type; content:"application/json"; pcre:"/[0-9a-f]{32,}/"; classtype:trojan-activity; sid:2026343; rev:1; metadata:mitre_technique_id T1071.001;)

# ============================================================
# 6. 流量行为分析 — Beacon 模式检测
# ============================================================

# 固定间隔 HTTP 连接 — C2 心跳特征
# 阈值：同一目标 10+ 次 GET 请求，间隔方差极小
alert http $HOME_NET any -> $EXTERNAL_NET any (msg:"ET C2 Beacon Pattern - Regular HTTP Interval"; flow:established,to_server; http.method; content:"GET"; threshold:type threshold, track by_src, count 10, seconds 60; classtype:trojan-activity; sid:2026350; rev:1; metadata:mitre_technique_id T1071.001;)

# 固定大小 TLS 应用数据 — C2 加密心跳
# 检测 TLS 应用数据长度方差极小的连接
alert tls $HOME_NET any -> $EXTERNAL_NET any (msg:"ET C2 Beacon Pattern - Consistent TLS Payload Size"; flow:established,to_server; tls.length; threshold:type both, track by_src, count 15, seconds 120; classtype:trojan-activity; sid:2026351; rev:1; metadata:mitre_technique_id T1573.002;)

# 双向 TLS 流量 — 仅 C2 使用 full TLS，正常 HTTP 用 TLS+HTTP
# 纯 TLS 应用数据无 HTTP 层 = 可能是 C2 隧道
alert tls $HOME_NET any -> $EXTERNAL_NET any (msg:"ET C2 Encrypted Tunnel - Non-HTTP TLS to External Host"; tls.version; content:"1.2"; flow:established; app-layer-protocol:tls; flowbits:set,et.c2.encrypted_tunnel; classtype:trojan-activity; sid:2026352; rev:1; metadata:mitre_technique_id T1572;)

# ============================================================
# 7. 已知 C2 域名/IP 情报 — 动态更新
# ============================================================

# Cobalt Strike Teamserver 默认证书 CN 检测
alert tls $HOME_NET any -> $EXTERNAL_NET any (msg:"ET C2 Cobalt Strike Default Certificate Subject"; tls.cert_subject; content:"CN="; pcre:"/CN=MajorTextField|CN=localhost|CN=cobaltstrike/"; classtype:trojan-activity; sid:2026360; rev:1; metadata:mitre_technique_id T1071.001;)

# 异常证书有效期 — C2 证书通常有效期极短
# 检测有效期 < 90 天的 TLS 证书（C2 工具特征）
alert tls $HOME_NET any -> $EXTERNAL_NET any (msg:"ET C2 Short-Lived TLS Certificate"; tls.cert_serial; content:"0"; tls.cert_validity; pcre:"/90d/"; classtype:trojan-activity; sid:2026361; rev:1; metadata:mitre_technique_id T1071.001;)

# 已知 C2 相关 TLS SNI 模式
alert tls $HOME_NET any -> $EXTERNAL_NET any (msg:"ET C2 Known C2 SNI Pattern - CloudFlare Hijacked Domain"; tls.sni; pcre:"/[a-z]{8,16}\.[a-z]{3,5}/"; content:"cloudflare"; no content; classtype:trojan-activity; sid:2026362; rev:1;)

# ============================================================
# 注意事项
# ============================================================
# 1. JA3/JA3S 指纹需要 Suricata 7.0+ 并启用 ja3 关键字
# 2. 生产环境部署前建议先观察 7 天误报率
# 3. JA3 指纹可被 Malleable C2 Profile 修改，需持续更新
# 4. DNS 隧道规则建议配合 threat intel 域名列表使用
# 5. Beacon 模式检测（2026350/2026351）需要较长观察窗口
# 6. SNI 无内容规则 (2026320) 可能对 IoT 设备误报，建议白名单
